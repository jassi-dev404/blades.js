{
  "appId": "com.bladejs.app",
  "productName": "Blade.js",
  "directories": {
    "output": "releases"
  },
  "files": [
    "dist/**/*",
    "electron/**/*"
  ],
  "mac": {
    "target": [
      "dmg",
      "zip"
    ],
    "category": "public.app-category.developer-tools",
    "icon": null
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": null
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": true
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Development"
  }
}
