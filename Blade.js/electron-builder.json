{
  "appId": "com.bladejs.app",
  "productName": "Blade.js",
  "directories": {
    "output": "releases"
  },
  "files": [
    "dist/**/*",
    "electron/**/*"
  ],
  "mac": {
    "target": [
      {
        "target": "dmg",
        "arch": ["arm64"]
      }
    ],
    "category": "public.app-category.developer-tools"
  },
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ]
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Development"
  }
}